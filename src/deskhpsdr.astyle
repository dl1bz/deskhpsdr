--style=java
--indent=spaces=2
--indent-continuation=4
--indent-preproc-block
--pad-oper
--pad-comma
--unpad-paren
--pad-header
--delete-empty-lines
--add-braces
--max-code-length=120
--break-after-logical
--mode=c
--indent-col1-comments
--convert-tabs
--keep-one-line-blocks
--align-pointer=name
--lineend=linux
